+}
+
+/// Represents a paginated result set
+#[derive(Debug, Clone)]
+pub struct PaginationResult<T> {
+    pub data: Vec<T>,
+    pub total: i64,
+    pub per_page: usize,
+    pub current_page: usize,
+    pub last_page: usize,
+}
