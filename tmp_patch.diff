+        .await?
+        .unwrap();
+    println!(
+        "Fetched User Preferences Theme: {}",
+        fetched_user.preferences.theme
+    );
+    println!(
+        "Fetched User Notifications Enabled: {}",
+        fetched_user.preferences.notifications_enabled
+    );
